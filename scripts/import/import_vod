#!/usr/bin/env python3
from __future__ import annotations

import json
import subprocess
import sys
import tempfile
from pathlib import Path

SCRIPT_ROOT = Path(__file__).resolve().parents[2]
if str(SCRIPT_ROOT) not in sys.path:
    sys.path.insert(0, str(SCRIPT_ROOT))

from scripts.lib.kb_common import ROOT, now_iso, rebuild_indexes, require_command, write_json
from scripts.lib.kb_vod import refresh_video_artifacts


DEFAULT_BROWSER = "brave"


def run_yt_dlp(args: list[str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(["yt-dlp", *args], text=True, capture_output=True, check=False)

def main() -> None:
    if len(sys.argv) != 2:
        raise SystemExit("Usage: scripts/import/import_vod <youtube-url>")

    require_command("yt-dlp")
    url = sys.argv[1]
    tmpdir = Path(tempfile.mkdtemp(prefix="riftbound-vod-"))

    info_result = run_yt_dlp(["--cookies-from-browser", DEFAULT_BROWSER, "--dump-single-json", "--skip-download", url])
    if info_result.returncode != 0:
        raise SystemExit(info_result.stderr.strip() or info_result.stdout.strip())
    metadata = json.loads(info_result.stdout)
    video_id = metadata["id"]

    subs_result = run_yt_dlp(
        [
            "--cookies-from-browser",
            DEFAULT_BROWSER,
            "--write-auto-subs",
            "--sub-langs",
            "en-orig",
            "--sub-format",
            "vtt",
            "--skip-download",
            "-o",
            "%(id)s.%(ext)s",
            "-P",
            str(tmpdir),
            url,
        ]
    )
    if subs_result.returncode != 0:
        raise SystemExit(subs_result.stderr.strip() or subs_result.stdout.strip())

    raw_caption_path = tmpdir / f"{video_id}.en-orig.vtt"
    if not raw_caption_path.exists():
        raise SystemExit(f"Expected caption file was not created: {raw_caption_path}")

    out_root = ROOT / "analysis" / "videos" / video_id
    out_root.mkdir(parents=True, exist_ok=True)

    meta_payload = {
        "id": f"analysis.video.{video_id}",
        "type": "analysis_note",
        "title": metadata.get("title", video_id),
        "source_kind": "youtube_vod_auto_caption",
        "source_path": url,
        "source_date": metadata.get("upload_date", "unknown"),
        "trust_level": "derived_unverified",
        "status": "draft",
        "tags": ["video", metadata.get("channel", "unknown"), video_id],
        "video_id": video_id,
        "channel": metadata.get("channel"),
        "uploader": metadata.get("uploader"),
        "duration_string": metadata.get("duration_string"),
        "webpage_url": metadata.get("webpage_url") or url,
        "transcript_type": "auto_caption_en_orig",
        "imported_at": now_iso(),
    }
    write_json(out_root / "metadata.json", meta_payload)
    raw_vtt = raw_caption_path.read_text(encoding="utf-8")
    (out_root / "captions.raw.vtt").write_text(raw_vtt, encoding="utf-8")
    refresh_video_artifacts(out_root)
    rebuild_indexes()


if __name__ == "__main__":
    main()
