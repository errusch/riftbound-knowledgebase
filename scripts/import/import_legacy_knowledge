def import_official_events(conn: sqlite3.Connection, db_path: Path, source_date: str) -> tuple[list[dict], list[dict]]:
    events_root = ROOT / "data" / "events" / "official"
    event_index = []
    deck_index = []

    deck_rows = conn.execute("SELECT * FROM rb_official_decklists ORDER BY event_id ASC, placement ASC, player_name ASC").fetchall()
    decks_by_event: dict[str, list[dict]] = defaultdict(list)
    for row in deck_rows:
        record = normalize_official_decklist(dict(row))
        decks_by_event[record["event_id"]].append(record)
        deck_index.append(
            {
                "id": f"official_decklist.{record['event_id']}.{safe_key(record['player_name'])}.{record['id']}",
                "title": f"{record['player_name']} - {record['legend']}",
                "event_id": record["event_id"],
                "placement": record["placement"],
                "legend": record["legend"],
                "champion": record["champion"],
                "deck_type": record["deck_type"],
            }
        )

    event_rows = conn.execute("SELECT * FROM rb_official_events ORDER BY date_start ASC, event_id ASC").fetchall()
    for row in event_rows:
        record = dict(row)
        payload = {
            "id": f"official_event.{safe_key(record['event_id'])}",
            "type": "event_record",
            "title": record["event_name"],
            "source_kind": "legacy_local_knowledge_db",
            "source_path": str(db_path),
            "source_date": source_date,
            "trust_level": "derived_verified",
            "status": "reviewed",
            "tags": ["official-event", record["format"] or "unknown"],
            "record": record,
            "decklists": decks_by_event.get(record["event_id"], []),
        }
        out_path = events_root / f"{safe_key(record['event_id'])}.json"
        write_json(out_path, payload)
        event_index.append(
            {
                **{k: v for k, v in payload.items() if k not in {"record", "decklists"}},
                "path": str(out_path.relative_to(ROOT)),
                "decklist_count_actual": len(payload["decklists"]),
            }
        )
    return event_index, deck_index


