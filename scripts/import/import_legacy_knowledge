def normalize_official_decklist(record: dict) -> dict:
    return {
        **record,
        "main_deck_cards": split_lines(record.get("main_deck")),
        "sideboard_cards": split_lines(record.get("sideboard")),
        "battlefield_cards": split_lines(record.get("battlefields")),
