        text_blob = "\n".join(part for part in [record.get("summary"), record.get("action_item")] if part)
        meta = analysis_meta(
            object_id=f"analysis.intel.bookmark.{record['id']}",
            title=f"Bookmark Intel {record['id']}",
            source_kind="legacy_local_knowledge_db_bookmark_intel",
            source_path=str(db_path),
            source_date=source_date,
            tags=["intel", record.get("category") or "unknown", record.get("source") or "unknown"],
            conflicts=[],
        )
        sections = [
            "## Summary",
            record.get("summary") or "_No summary stored._",
            "",
            "## Actionability",
            f"- Actionable: {bool(record.get('actionable'))}",
            f"- Action Item: {record.get('action_item') or 'none'}",
            "",
            "## Source Metadata",
            f"- Author: {record.get('author') or 'unknown'}",
            f"- Category: {record.get('category') or 'unknown'}",
            f"- Tweet URL: {record.get('tweet_url') or 'unknown'}",
            f"- Date: {record.get('date') or 'unknown'}",
            f"- Source: {record.get('source') or 'unknown'}",
        ]
        out_path = out_root / f"bookmark-{record['id']}.md"
        index.append(write_analysis_note(out_path, meta, sections, text_blob or str(record["id"])))
    return index


def main() -> None:
    db_path = choose_db_path()
    source_date = source_date_for(db_path)

    card_import = run([str(ROOT / "scripts" / "import" / "import_local_cards")])
    if card_import.returncode != 0:
        raise SystemExit(card_import.stderr.strip() or card_import.stdout.strip())

    with sqlite3.connect(db_path) as conn:
        conn.row_factory = sqlite3.Row

        merge_legends_taxonomy(conn)
        merge_battlefields_taxonomy(conn)

        indexes = {
            "sets": import_sets(conn, db_path, source_date),
            "rulings": import_rulings(conn, db_path, source_date),
        }
        official_events_index, official_decklists_index = import_official_events(conn, db_path, source_date)
        indexes["official_events"] = official_events_index
        indexes["official_decklists"] = official_decklists_index
        indexes["precon_decks"] = import_precon_decks(conn, db_path, source_date)
        indexes["tournaments_db"] = import_tournaments(conn, db_path, source_date)
        indexes["prices_latest"] = import_price_history(conn, db_path, source_date)
        indexes["keywords"] = import_keywords(conn, db_path, source_date)
        indexes["meta_tiers"] = import_meta_tiers(conn, db_path, source_date)
        indexes["op_schedule"] = import_schedule(conn, db_path, source_date)
        indexes["competitive_players_db"] = import_players(conn, db_path, source_date)
        indexes["guides"] = import_guides(conn, db_path, source_date)
        indexes["content_creators"] = import_creators(conn, db_path, source_date)
        indexes["community_posts"] = import_community_posts(conn, db_path, source_date)
        indexes["bookmark_intel"] = import_bookmark_intel(conn, db_path, source_date)

    for name, payload in indexes.items():
        write_json(ROOT / "data" / "indexes" / f"{name}.json", payload)

    summary = {
        "source_path": str(db_path),
        "source_date": source_date,
        "counts": {name: len(payload) for name, payload in indexes.items()},
        "taxonomy": {
            "legends": len(load_json(ROOT / "data" / "taxonomy" / "legends.json", [])),
            "battlefields": len(load_json(ROOT / "data" / "taxonomy" / "battlefields.json", [])),
        },
    }
    write_json(ROOT / "data" / "indexes" / "legacy_db_summary.json", summary)
    rebuild_indexes()


if __name__ == "__main__":
    main()
