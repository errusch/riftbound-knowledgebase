def choose_db_path() -> Path:
    candidate = find_legacy_knowledge_db("riftbound_cards")
    if candidate is None:
        raise SystemExit("Unable to locate a local knowledge.db containing Riftbound data.")
    return candidate


def source_date_for(path: Path) -> str:
    return datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc).isoformat().replace("+00:00", "Z")


def safe_key(value: str | int | None, fallback: str = "item") -> str:
    if value is None:
        return fallback
    cleaned = slugify(str(value))
    return cleaned or fallback


def parse_jsonish(raw: str | None):
    if raw is None:
        return None
    text = raw.strip()
    if not text:
        return None
    if text[0] not in "[{":
        return raw
    try:
        return json.loads(text)
    except json.JSONDecodeError:
        return raw


def split_lines(raw: str | None) -> list[str]:
    if raw is None:
        return []
    return [line.strip() for line in str(raw).splitlines() if line.strip()]


def split_semicolons(raw: str | None) -> list[str]:
    if raw is None:
        return []
    return [part.strip() for part in str(raw).split(";") if part.strip()]


def split_commas(raw: str | None) -> list[str]:
    if raw is None:
        return []
    return [part.strip() for part in str(raw).split(",") if part.strip()]


def markdown_list(items: list[str]) -> list[str]:
    if not items:
        return ["- none"]
    return [f"- {item}" for item in items]


def analysis_meta(
    object_id: str,
    title: str,
    source_kind: str,
    source_path: str,
    source_date: str,
    tags: list[str],
    conflicts: list[dict],
) -> dict:
    return {
        "id": object_id,
        "type": "analysis_note",
        "title": title,
        "source_kind": source_kind,
        "source_path": source_path,
        "source_date": source_date,
        "trust_level": "conflicted" if conflicts else "derived_unverified",
        "status": "reviewed",
        "tags": tags,
    }


def write_analysis_note(out_path: Path, meta: dict, sections: list[str], claims_seed: str) -> dict:
    body = "\n".join(sections)
    write_markdown(out_path, meta, body)
    claims = extract_claims(claims_seed)
    claims_path = out_path.with_suffix(".claims.json")
    write_json(claims_path, claims)
    return {**meta, "path": str(out_path.relative_to(ROOT)), "claims_path": str(claims_path.relative_to(ROOT))}


def merge_legends_taxonomy(conn: sqlite3.Connection) -> None:
    existing = load_json(ROOT / "data" / "taxonomy" / "legends.json", [])
    merged: dict[str, set[str]] = {item["name"]: set(item.get("aliases", [])) for item in existing if item.get("name")}

    for row in conn.execute("SELECT card_name, full_name, champion_name FROM legend_name_mapping ORDER BY full_name ASC"):
        full_name = row["full_name"]
        champion_name = row["champion_name"] or full_name
        aliases = merged.setdefault(champion_name, set())
        aliases.update({champion_name.lower(), full_name.lower()})
        if row["card_name"]:
            aliases.add(str(row["card_name"]).lower())

    payload = [{"name": name, "aliases": sorted(alias for alias in aliases if alias)} for name, aliases in sorted(merged.items())]
    write_json(ROOT / "data" / "taxonomy" / "legends.json", payload)


def merge_battlefields_taxonomy(conn: sqlite3.Connection) -> None:
    existing = load_json(ROOT / "data" / "taxonomy" / "battlefields.json", [])
    merged: dict[str, set[str]] = {item["name"]: set(item.get("aliases", [])) for item in existing if item.get("name")}

    rows = conn.execute("SELECT name FROM riftbound_cards WHERE type = 'Battlefield' ORDER BY name ASC").fetchall()
    for row in rows:
        name = row["name"]
        aliases = merged.setdefault(name, set())
        lowered = name.lower()
        aliases.add(lowered)
        aliases.add(re.sub(r"[^a-z0-9]+", " ", lowered).strip())
        aliases.add(re.sub(r"[^a-z0-9]+", "", lowered))

    payload = [{"name": name, "aliases": sorted(alias for alias in aliases if alias)} for name, aliases in sorted(merged.items())]
    write_json(ROOT / "data" / "taxonomy" / "battlefields.json", payload)


