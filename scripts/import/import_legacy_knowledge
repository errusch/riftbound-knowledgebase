            "source_path": str(db_path),
            "source_date": source_date,
            "trust_level": "derived_verified",
            "status": "reviewed",
            "tags": ["tournament", record["format"] or "unknown", safe_key(record.get("city"))],
            "record": record,
            "rounds": rounds_by_tid.get(record["tid"], []),
            "standings": standings_by_tid.get(record["tid"], []),
        }
        out_path = out_root / f"{key}.json"
        write_json(out_path, payload)
        index.append(
            {
                **{k: v for k, v in payload.items() if k not in {"record", "rounds", "standings"}},
                "path": str(out_path.relative_to(ROOT)),
                "round_count": len(payload["rounds"]),
