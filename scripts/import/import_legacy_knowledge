def import_guides(conn: sqlite3.Connection, db_path: Path, source_date: str) -> list[dict]:
    out_root = ROOT / "analysis" / "guides"
    index = []
    rows = conn.execute("SELECT * FROM rb_guides ORDER BY title ASC").fetchall()
    for row in rows:
        record = dict(row)
        text_blob = "\n".join(part for part in [record.get("summary"), record.get("key_facts")] if part)
        conflicts = detect_conflicts(text_blob)
        meta = analysis_meta(
            object_id=f"analysis.guide.{safe_key(record['title'])}",
            title=record["title"],
            source_kind="legacy_local_knowledge_db_guide",
            source_path=str(db_path),
            source_date=source_date,
            tags=["guide", safe_key(record.get("legend")), record.get("source") or "unknown"],
            conflicts=conflicts,
        )
        sections = [
            "## Summary",
            record.get("summary") or "_No summary stored in the local database._",
            "",
            "## Key Facts",
            *(split_lines(record.get("key_facts")) or ["- none stored"]),
            "",
            "## Source Metadata",
            f"- URL: {record.get('url') or 'unknown'}",
            f"- Article Type: {record.get('article_type') or 'unknown'}",
            f"- Legend: {record.get('legend') or 'unknown'}",
            f"- Source: {record.get('source') or 'unknown'}",
            f"- Imported From: `{db_path}`",
        ]
        if conflicts:
            sections.extend(["", "## Conflict Flags", *markdown_list([f"`{item['id']}`: {item['message']}" for item in conflicts])])
        out_path = out_root / f"{safe_key(record['title'])}.md"
        index.append(write_analysis_note(out_path, meta, sections, text_blob))
    return index


