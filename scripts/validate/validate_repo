#!/usr/bin/env python3
from __future__ import annotations

from pathlib import Path
import sys

SCRIPT_ROOT = Path(__file__).resolve().parents[2]
if str(SCRIPT_ROOT) not in sys.path:
    sys.path.insert(0, str(SCRIPT_ROOT))

from scripts.lib.kb_common import IGNORED_DUPLICATE_ROOT, ROOT, detect_conflicts, load_json


def fail(message: str) -> None:
    raise SystemExit(message)


def main() -> None:
    verified_guide_expectations = {
        "analysis.guide.deckbuilding-101-building-your-first-riftbound-deck": {"verified-guide", "game-reference"},
        "analysis.guide.domain-101-understanding-the-six-domains-of-riftbound": {"verified-guide", "game-reference"},
        "analysis.guide.battlefields-101-attacking-and-trading-units": {"verified-guide", "game-reference"},
        "analysis.guide.movement-101-advanced-movement-ganking-and-combos": {"verified-guide", "game-reference"},
        "analysis.guide.draven-glorious-executioner-guide": {"verified-guide", "legend-reference"},
        "analysis.guide.kai-sa-daughter-of-the-void-guide": {"verified-guide", "legend-reference"},
        "analysis.guide.kai-sa-daughter-of-the-void-deck-in-numbers": {"verified-guide", "legend-reference"},
        "analysis.guide.riftbound-meta-tier-list-global-release-post-chinese-regionals": {"verified-guide", "meta-reference"},
        "analysis.guide.ahri-nine-tailed-fox-guide": {"verified-guide", "legend-reference"},
        "analysis.guide.annie-dark-child-starter-guide": {"verified-guide", "legend-reference"},
        "analysis.guide.master-yi-wuju-bladesman-guide": {"verified-guide", "legend-reference"},
        "analysis.guide.leona-radiant-dawn-guide": {"verified-guide", "legend-reference"},
    }

    required_paths = [
        ROOT / "canon" / "rules" / "core-rules-v1-2.md",
        ROOT / "canon" / "tournament" / "tournament-rules-2025-10-16.md",
        ROOT / "canon" / "errata" / "card-errata-set-1-origins.md",
        ROOT / "analysis" / "reference" / "tournament-rules.md",
        ROOT / "analysis" / "guides",
        ROOT / "analysis" / "creators",
        ROOT / "analysis" / "community",
        ROOT / "analysis" / "intel",
        ROOT / "analysis" / "videos" / "m2IjrsUzXgU" / "review.md",
        ROOT / "data" / "indexes" / "canon_documents.json",
        ROOT / "data" / "indexes" / "cards_full.json",
        ROOT / "data" / "indexes" / "legacy_db_summary.json",
        ROOT / "data" / "indexes" / "sets.json",
        ROOT / "data" / "indexes" / "rulings.json",
        ROOT / "data" / "indexes" / "official_events.json",
        ROOT / "data" / "indexes" / "official_decklists.json",
        ROOT / "data" / "indexes" / "precon_decks.json",
        ROOT / "data" / "indexes" / "tournaments_db.json",
        ROOT / "data" / "indexes" / "prices_latest.json",
        ROOT / "data" / "indexes" / "keywords.json",
        ROOT / "data" / "indexes" / "meta_tiers.json",
        ROOT / "data" / "indexes" / "op_schedule.json",
        ROOT / "data" / "indexes" / "guides.json",
        ROOT / "data" / "indexes" / "content_creators.json",
        ROOT / "data" / "indexes" / "community_posts.json",
        ROOT / "data" / "indexes" / "bookmark_intel.json",
        ROOT / "data" / "indexes" / "decks.json",
        ROOT / "data" / "indexes" / "events.json",
        ROOT / "data" / "indexes" / "videos.json",
        ROOT / "data" / "indexes" / "derived_conflicts.json",
        ROOT / "data" / "indexes" / "data_objects.json",
        ROOT / "data" / "indexes" / "graph_edges.json",
        ROOT / "data" / "indexes" / "quality_report.json",
        ROOT / "data" / "indexes" / "card_to_rulings.json",
        ROOT / "data" / "indexes" / "card_to_guides.json",
        ROOT / "data" / "indexes" / "legend_to_decks.json",
        ROOT / "data" / "indexes" / "legend_to_matchups.json",
        ROOT / "data" / "indexes" / "event_to_top_lists.json",
        ROOT / "data" / "indexes" / "battlefield_to_mentions.json",
        ROOT / "data" / "indexes" / "concept_to_vods.json",
        ROOT / "data" / "indexes" / "conflicts_by_topic.json",
        ROOT / "data" / "indexes" / "cards_lookup.json",
        ROOT / "data" / "indexes" / "legend_lookup.json",
        ROOT / "data" / "indexes" / "meta_snapshots.json",
        ROOT / "data" / "indexes" / "vod_links.json",
        ROOT / "data" / "taxonomy" / "trust_policy.json",
        ROOT / "data" / "indexes" / "prep_briefs" / "draven-vs-kaisa.json",
        ROOT / "data" / "meta" / "2026-03-27.json",
        ROOT / "analysis" / "meta" / "2026-03-27.md",
        ROOT / "analysis" / "archetypes" / "draven.md",
        ROOT / "analysis" / "matchups" / "draven-vs-kaisa.md",
        ROOT / "scripts" / "query" / "kb",
        ROOT / "scripts" / "ops" / "kb_ops",
        ROOT / "scripts" / "build" / "rebuild_graph_indexes",
        ROOT / "scripts" / "validate" / "run_regression_tests",
    ]
    missing = [str(path.relative_to(ROOT)) for path in required_paths if not path.exists()]
    if missing:
        fail(f"Missing expected artifacts: {', '.join(missing)}")

    canon_documents = load_json(ROOT / "data" / "indexes" / "canon_documents.json", [])
    if len(canon_documents) < 4:
        fail("Expected at least four imported canon documents.")

    conflicts = load_json(ROOT / "data" / "indexes" / "derived_conflicts.json", [])
    conflict_ids = {item["id"] for item in conflicts}
    for required_conflict in {"tournament.additional_turns", "tournament.two_point_lead"}:
        if required_conflict not in conflict_ids:
            fail(f"Expected conflict rule not triggered: {required_conflict}")

    decks = load_json(ROOT / "data" / "indexes" / "decks.json", [])
    events = load_json(ROOT / "data" / "indexes" / "events.json", [])
    if not decks or not events:
        fail("Competitive deck or event indexes are empty.")

    cards_full = load_json(ROOT / "data" / "indexes" / "cards_full.json", [])
    if len(cards_full) < 600:
        fail("Expected at least 600 fully imported local card records.")

    legacy_summary = load_json(ROOT / "data" / "indexes" / "legacy_db_summary.json", {})
    for key, minimum in {
        "sets": 6,
        "rulings": 30,
        "official_events": 6,
        "official_decklists": 80,
        "precon_decks": 4,
        "tournaments_db": 100,
        "prices_latest": 600,
        "keywords": 15,
        "meta_tiers": 10,
        "op_schedule": 20,
        "guides": 60,
        "content_creators": 10,
        "community_posts": 20,
        "bookmark_intel": 100,
    }.items():
        actual = legacy_summary.get("counts", {}).get(key, 0)
        if actual < minimum:
            fail(f"Legacy DB import index too small for {key}: expected >= {minimum}, got {actual}")

    all_objects = load_json(ROOT / "data" / "indexes" / "all_objects.json", [])
    if any(not obj.get("id") or not obj.get("type") or not obj.get("title") for obj in all_objects):
        fail("Object index contains entries with missing id/type/title metadata.")
    duplicate_root = str(IGNORED_DUPLICATE_ROOT)
    for obj in all_objects + decks + events:
        source_path = obj.get("source_path") or ""
        if duplicate_root in source_path:
            fail(f"Unexpected duplicate-repo import detected: {source_path}")

    rules_atoms = load_json(ROOT / "data" / "indexes" / "rules_atoms.json", [])
    if not any("battlefield" in atom.get("text", "").lower() for atom in rules_atoms):
        fail("Rules atom index is missing battlefield-related entries.")

    battlefields = load_json(ROOT / "data" / "taxonomy" / "battlefields.json", [])
    if len(battlefields) < 30:
        fail("Battlefield taxonomy should contain at least 30 entries from the full local corpus.")

    graph_edges = load_json(ROOT / "data" / "indexes" / "graph_edges.json", [])
    if len(graph_edges) < 50:
        fail("Graph edge index is unexpectedly small.")

    card_to_rulings = load_json(ROOT / "data" / "indexes" / "card_to_rulings.json", {})
    if "card.ogn-107-298" not in card_to_rulings:
        fail("Expected Ava Achiever ruling links in card_to_rulings index.")

    card_to_guides = load_json(ROOT / "data" / "indexes" / "card_to_guides.json", {})
    if "card.ogn-107-298" not in card_to_guides:
        fail("Expected Ava Achiever guide links in card_to_guides index.")

    legend_to_decks = load_json(ROOT / "data" / "indexes" / "legend_to_decks.json", {})
    for legend in {"Draven", "Kai'Sa", "Annie"}:
        if legend not in legend_to_decks:
            fail(f"Legend deck index missing expected legend: {legend}")

    legend_to_matchups = load_json(ROOT / "data" / "indexes" / "legend_to_matchups.json", {})
    if "Draven" not in legend_to_matchups:
        fail("Legend matchup index should include Draven after generated prep artifacts.")

    event_to_top_lists = load_json(ROOT / "data" / "indexes" / "event_to_top_lists.json", {})
    if "event.houston-regional-qualifier" not in event_to_top_lists:
        fail("Event to top lists index is missing the Houston Regional Qualifier.")

    battlefield_to_mentions = load_json(ROOT / "data" / "indexes" / "battlefield_to_mentions.json", {})
    if "Reaver's Row" not in battlefield_to_mentions:
        fail("Battlefield mentions index should include Reaver's Row.")

    concept_to_vods = load_json(ROOT / "data" / "indexes" / "concept_to_vods.json", {})
    if "battlefield order" not in concept_to_vods:
        fail("Concept-to-VOD index should include battlefield order.")

    conflicts_by_topic = load_json(ROOT / "data" / "indexes" / "conflicts_by_topic.json", [])
    if not any(item.get("topic") == "tournament" for item in conflicts_by_topic):
        fail("Conflicts-by-topic index should include the tournament topic.")

    cards_lookup = load_json(ROOT / "data" / "indexes" / "cards_lookup.json", [])
    if not any(item.get("lookup_key") == "ava achiever" for item in cards_lookup):
        fail("Cards lookup index should include Ava Achiever.")

    legend_lookup = load_json(ROOT / "data" / "indexes" / "legend_lookup.json", [])
    if not any(item.get("lookup_key") == "daughter of the void" for item in legend_lookup):
        fail("Legend lookup index should include Kai'Sa aliases.")

    meta_snapshots = load_json(ROOT / "data" / "indexes" / "meta_snapshots.json", [])
    if not meta_snapshots:
        fail("Generated meta snapshot index should not be empty.")

    quality_report = load_json(ROOT / "data" / "indexes" / "quality_report.json", {})
    if "draft_objects" not in quality_report or "conflicted_by_topic" not in quality_report or "active_review_queue" not in quality_report:
        fail("Quality report is missing required trust/report sections.")

    object_map = {item["id"]: item for item in all_objects}
    for promoted_id in {"analysis.reference.core-rules", "analysis.reference.mechanics"}:
        if object_map.get(promoted_id, {}).get("trust_level") != "derived_verified":
            fail(f"Expected promoted trust level for {promoted_id}.")

    for guide_id, required_tags in verified_guide_expectations.items():
        guide = object_map.get(guide_id, {})
        if guide.get("trust_level") != "derived_verified":
            fail(f"Expected verified guide trust level for {guide_id}.")
        guide_tags = set(guide.get("tags", []) or [])
        if not required_tags.issubset(guide_tags):
            fail(f"Expected verified guide tags for {guide_id}: missing {sorted(required_tags - guide_tags)}")
        if not guide.get("summary_claims"):
            fail(f"Expected non-empty summary claims for verified guide {guide_id}.")
        if not guide.get("evidence_links"):
            fail(f"Expected non-empty evidence links for verified guide {guide_id}.")
        if guide.get("verification_mode") != "strict_proof":
            fail(f"Expected strict proof verification mode for {guide_id}.")
        if guide.get("claim_policy") != "split_claims":
            fail(f"Expected split-claims policy for {guide_id}.")

    player_draven = object_map.get("player.draven", {})
    player_tags = set(player_draven.get("tags", []) or [])
    if not {"quarantined", "non-authoritative", "low-confidence"}.issubset(player_tags):
        fail("Expected player records to be quarantined and marked non-authoritative.")

    conflicted_tournament_rules = object_map.get("analysis.reference.tournament-rules", {})
    if conflicted_tournament_rules.get("trust_level") != "conflicted":
        fail("Expected derived tournament rules summary to remain conflicted.")

    vod_links = load_json(ROOT / "data" / "indexes" / "vod_links.json", [])
    if not any(item.get("object_id") == "analysis.video_review.m2IjrsUzXgU" for item in vod_links):
        fail("VOD links index should include the existing NovaRiftbound review.")

    prep_briefs_root = ROOT / "data" / "indexes" / "prep_briefs"
    prep_briefs = sorted(prep_briefs_root.glob("*.json"))
    if len(prep_briefs) < 5:
        fail("Expected at least five generated prep briefs after hardening expansion.")

    trust_policy = load_json(ROOT / "data" / "taxonomy" / "trust_policy.json", {})
    verification_manifest = {
        item.get("id"): item
        for item in trust_policy.get("verification_manifest", [])
        if isinstance(item, dict) and item.get("id")
    }
    manifest_ids = set(verification_manifest)
    if not set(verified_guide_expectations).issubset(manifest_ids):
        fail("Trust policy verification manifest is missing one or more promoted guides.")
    for guide_id in verified_guide_expectations:
        record = verification_manifest.get(guide_id, {})
        if record.get("verification_mode") != "strict_proof":
            fail(f"Expected strict-proof manifest for {guide_id}.")
        if record.get("claim_policy") != "split_claims":
            fail(f"Expected split-claims manifest for {guide_id}.")
        if not record.get("summary_claims"):
            fail(f"Expected summary claims in verification manifest for {guide_id}.")
        if not record.get("evidence_links"):
            fail(f"Expected evidence links in verification manifest for {guide_id}.")
        if any(not isinstance(item, dict) or not item.get("claim") or not item.get("evidence_links") for item in record.get("summary_claims", [])):
            fail(f"Expected structured claim records in verification manifest for {guide_id}.")
        for evidence_id in record.get("evidence_links", []):
            if evidence_id not in object_map:
                fail(f"Expected evidence link {evidence_id} to resolve for {guide_id}.")
        for claim in record.get("summary_claims", []):
            for evidence_id in claim.get("evidence_links", []):
                if evidence_id not in object_map:
                    fail(f"Expected summary-claim evidence link {evidence_id} to resolve for {guide_id}.")

    verified_guides = quality_report.get("verified_guides", {})
    verified_objects = verified_guides.get("objects", [])
    verified_ids = {item.get("id") for item in verified_objects}
    if verified_guides.get("count", 0) < len(verified_guide_expectations):
        fail("Quality report should expose at least the full verified guide pack count.")
    if not set(verified_guide_expectations).issubset(verified_ids):
        fail("Quality report verified guide section is missing one or more promoted guides.")

    active_review_ids = {
        item["id"]
        for items in quality_report.get("active_review_queue", {}).values()
        for item in items.get("objects", [])
    }
    if active_review_ids.intersection(verified_guide_expectations):
        fail("Promoted verified guides should not remain in the active review queue.")

    for guide_id in verified_guide_expectations:
        guide_path = ROOT / object_map[guide_id]["path"]
        guide_body = guide_path.read_text(encoding="utf-8")
        if detect_conflicts(guide_body):
            fail(f"Verified guide {guide_id} should not trip local conflict rules.")

    print("Validation passed.")


if __name__ == "__main__":
    main()
