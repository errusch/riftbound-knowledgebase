#!/usr/bin/env python3
from __future__ import annotations

from pathlib import Path
import sys

SCRIPT_ROOT = Path(__file__).resolve().parents[2]
if str(SCRIPT_ROOT) not in sys.path:
    sys.path.insert(0, str(SCRIPT_ROOT))

from scripts.lib.kb_common import IGNORED_DUPLICATE_ROOT, ROOT, load_json


def fail(message: str) -> None:
    raise SystemExit(message)


def main() -> None:
    required_paths = [
        ROOT / "canon" / "rules" / "core-rules-v1-2.md",
        ROOT / "canon" / "tournament" / "tournament-rules-2025-10-16.md",
        ROOT / "canon" / "errata" / "card-errata-set-1-origins.md",
        ROOT / "analysis" / "reference" / "tournament-rules.md",
        ROOT / "analysis" / "guides",
        ROOT / "analysis" / "creators",
        ROOT / "analysis" / "community",
        ROOT / "analysis" / "intel",
        ROOT / "analysis" / "videos" / "m2IjrsUzXgU" / "review.md",
        ROOT / "data" / "indexes" / "canon_documents.json",
        ROOT / "data" / "indexes" / "cards_full.json",
        ROOT / "data" / "indexes" / "legacy_db_summary.json",
        ROOT / "data" / "indexes" / "sets.json",
        ROOT / "data" / "indexes" / "rulings.json",
        ROOT / "data" / "indexes" / "official_events.json",
        ROOT / "data" / "indexes" / "official_decklists.json",
        ROOT / "data" / "indexes" / "precon_decks.json",
        ROOT / "data" / "indexes" / "tournaments_db.json",
        ROOT / "data" / "indexes" / "prices_latest.json",
        ROOT / "data" / "indexes" / "keywords.json",
        ROOT / "data" / "indexes" / "meta_tiers.json",
        ROOT / "data" / "indexes" / "op_schedule.json",
        ROOT / "data" / "indexes" / "guides.json",
        ROOT / "data" / "indexes" / "content_creators.json",
        ROOT / "data" / "indexes" / "community_posts.json",
        ROOT / "data" / "indexes" / "bookmark_intel.json",
        ROOT / "data" / "indexes" / "decks.json",
        ROOT / "data" / "indexes" / "events.json",
        ROOT / "data" / "indexes" / "videos.json",
        ROOT / "data" / "indexes" / "derived_conflicts.json",
    ]
    missing = [str(path.relative_to(ROOT)) for path in required_paths if not path.exists()]
    if missing:
        fail(f"Missing expected artifacts: {', '.join(missing)}")

    canon_documents = load_json(ROOT / "data" / "indexes" / "canon_documents.json", [])
    if len(canon_documents) < 4:
        fail("Expected at least four imported canon documents.")

    conflicts = load_json(ROOT / "data" / "indexes" / "derived_conflicts.json", [])
    conflict_ids = {item["id"] for item in conflicts}
    for required_conflict in {"tournament.additional_turns", "tournament.two_point_lead"}:
        if required_conflict not in conflict_ids:
            fail(f"Expected conflict rule not triggered: {required_conflict}")

    decks = load_json(ROOT / "data" / "indexes" / "decks.json", [])
    events = load_json(ROOT / "data" / "indexes" / "events.json", [])
    if not decks or not events:
        fail("Competitive deck or event indexes are empty.")

    cards_full = load_json(ROOT / "data" / "indexes" / "cards_full.json", [])
    if len(cards_full) < 600:
        fail("Expected at least 600 fully imported local card records.")

    legacy_summary = load_json(ROOT / "data" / "indexes" / "legacy_db_summary.json", {})
    for key, minimum in {
        "sets": 6,
        "rulings": 30,
        "official_events": 6,
        "official_decklists": 80,
        "precon_decks": 4,
        "tournaments_db": 100,
        "prices_latest": 600,
        "keywords": 15,
        "meta_tiers": 10,
        "op_schedule": 20,
        "guides": 60,
        "content_creators": 10,
        "community_posts": 20,
        "bookmark_intel": 100,
    }.items():
        actual = legacy_summary.get("counts", {}).get(key, 0)
        if actual < minimum:
            fail(f"Legacy DB import index too small for {key}: expected >= {minimum}, got {actual}")

    all_objects = load_json(ROOT / "data" / "indexes" / "all_objects.json", [])
    duplicate_root = str(IGNORED_DUPLICATE_ROOT)
    for obj in all_objects + decks + events:
        source_path = obj.get("source_path", "")
        if duplicate_root in source_path:
            fail(f"Unexpected duplicate-repo import detected: {source_path}")

    rules_atoms = load_json(ROOT / "data" / "indexes" / "rules_atoms.json", [])
    if not any("battlefield" in atom.get("text", "").lower() for atom in rules_atoms):
        fail("Rules atom index is missing battlefield-related entries.")

    battlefields = load_json(ROOT / "data" / "taxonomy" / "battlefields.json", [])
    if len(battlefields) < 30:
        fail("Battlefield taxonomy should contain at least 30 entries from the full local corpus.")

    print("Validation passed.")


if __name__ == "__main__":
    main()
