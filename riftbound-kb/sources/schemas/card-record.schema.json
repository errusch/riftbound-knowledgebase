{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "riftbound-kb/schemas/card-record.schema.json",
  "title": "Riftbound Card Record",
  "type": "object",
  "required": [
    "card_id",
    "name",
    "set_code",
    "collector_number",
    "card_type",
    "domains",
    "text",
    "rarity",
    "source"
  ],
  "properties": {
    "card_id": {"type": "string"},
    "name": {"type": "string"},
    "set_code": {"type": "string"},
    "set_name": {"type": "string"},
    "collector_number": {"type": "string"},
    "card_type": {"type": "string"},
    "subtypes": {"type": "array", "items": {"type": "string"}},
    "domains": {"type": "array", "items": {"type": "string"}},
    "energy": {
      "type": ["integer", "string", "null"],
      "description": "Energy cost to play the card (the circle/pip value in the top-left of the printed card)."
    },
    "power": {
      "type": ["integer", "string", "null"],
      "description": "Power (rune) cost. Sum of domain pips required in the player's rune pool."
    },
    "might": {
      "type": ["integer", "string", "null"],
      "description": "Combat stat of a Unit (sword-and-shield icon, top-right). Determines both damage dealt and damage survivable."
    },
    "might_bonus": {
      "type": ["integer", "string", "null"],
      "description": "Might modifier applied while this card is attached to another (Gear, attachments)."
    },
    "text": {"type": "string"},
    "rarity": {"type": "string"},
    "image": {
      "type": "object",
      "properties": {
        "path": {"type": ["string", "null"]},
        "url": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "legality": {
      "type": "object",
      "properties": {
        "constructed": {"type": ["string", "null"]},
        "limited": {"type": ["string", "null"]},
        "notes": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "errata_links": {"type": "array", "items": {"type": "string"}},
    "rulings_links": {"type": "array", "items": {"type": "string"}},
    "source": {"$ref": "./source-record.schema.json"},
    "notes": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
